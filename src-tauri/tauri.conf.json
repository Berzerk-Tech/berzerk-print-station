{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Berzerk RFID",
  "version": "0.1.7",
  "identifier": "com.berzerk.printstation",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Berzerk RFID",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Berzerk-Tech/berzerk-rfid/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwQjg3QTE0OUFFOTQ2MjYKUldRbVJ1bWFGSHE0Y0dPZytrRzZsdkdnK0xwejFzSXUrMy80bU5vaWdFa2NFSGJrcGJkbEIxS0MK"
    }
  }
}
